# -----------------------------
# Core database
# -----------------------------
MONGO_ATLAS_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DATABASE=eventzen

# -----------------------------
# JWT
# -----------------------------
JWT_SECRET=replace-with-strong-jwt-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=1h
JWT_PASSWORD_RESET_EXPIRES_IN=15m

# -----------------------------
# Security and internal service auth
# -----------------------------
BCRYPT_SALT_ROUNDS=10
INTERNAL_SERVICE_SECRET=replace-with-shared-internal-secret
INTERNAL_SIGNATURE_TTL_MS=60000

# -----------------------------
# Frontend and CORS
# -----------------------------
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://192.168.0.244:5173

# -----------------------------
# SMTP
# -----------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=replace-with-smtp-app-password
SMTP_FROM=your-email@example.com
SMTP_DISPLAY_NAME=EventZen

# -----------------------------
# Cloudinary
# -----------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# -----------------------------
# Payments
# -----------------------------
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
PAYMENT_CURRENCY=INR
CONVENIENCE_FEE_PERCENT=5

# -----------------------------
# AI
# -----------------------------
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# -----------------------------
# API gateway auth rate limits
# -----------------------------
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_OTP_RATE_LIMIT_MAX_ATTEMPTS=5

# -----------------------------
# Monitoring
# -----------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
