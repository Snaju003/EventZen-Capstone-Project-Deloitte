PORT=3001
JWT_SECRET=replace-with-strong-jwt-secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_REFRESH_EXPIRES_IN=1h
JWT_PASSWORD_RESET_EXPIRES_IN=15m
BCRYPT_SALT_ROUNDS=10
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=your-sender@example.com
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
EVENT_SERVICE_URL=http://localhost:8080
INTERNAL_SERVICE_SECRET=replace-with-strong-random-secret
IDENTITY_SIGNATURE_SECRET=replace-with-strong-signature-secret
