{{ with secret "secret/data/eventzen/auth-service" -}}
MONGODB_URI="{{ .Data.data.MONGODB_URI }}"
JWT_SECRET="{{ .Data.data.JWT_SECRET }}"
JWT_REFRESH_SECRET="{{ .Data.data.JWT_REFRESH_SECRET }}"
SMTP_USER="{{ .Data.data.SMTP_USER }}"
SMTP_PASS="{{ .Data.data.SMTP_PASS }}"
SMTP_FROM="{{ .Data.data.SMTP_FROM }}"
CLOUDINARY_CLOUD_NAME="{{ .Data.data.CLOUDINARY_CLOUD_NAME }}"
CLOUDINARY_API_KEY="{{ .Data.data.CLOUDINARY_API_KEY }}"
CLOUDINARY_API_SECRET="{{ .Data.data.CLOUDINARY_API_SECRET }}"
INTERNAL_SERVICE_SECRET="{{ .Data.data.INTERNAL_SERVICE_SECRET }}"
{{- end }}
