PORT=3003
MONGODB_URI=mongodb://localhost:27017/notification-service
KAFKA_BROKER=kafka:9092
# If notification-service runs on host instead of Docker, set KAFKA_BROKER=localhost:9094
KAFKA_CLIENT_ID=eventzen-notification-service
KAFKA_CONSUMER_GROUP=eventzen-notification-consumer-group
KAFKA_CONNECT_RETRY_MS=5000
INTERNAL_CALLER_NAME=notification-service
INTERNAL_SERVICE_SECRET=replace-with-shared-internal-secret
INTERNAL_SIGNATURE_TTL_MS=60000
