MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DATABASE=eventzen
SERVER_PORT=8080
LOG_LEVEL=INFO

# Groq AI
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
KAFKA_BROKER=kafka:9092
# For local host-run services (outside Docker), use localhost:9094
KAFKA_CLIENT_ID=eventzen-event-service
BOOKING_SERVICE_URL=http://booking-service:5000
INTERNAL_CALLER_NAME=event-service
INTERNAL_SERVICE_SECRET=replace-with-shared-internal-secret
INTERNAL_SIGNATURE_TTL_MS=60000
